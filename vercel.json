{
  "version": 2,
  "installCommand": "echo skip",
  "buildCommand": "echo skip",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/roblox-callback",  "destination": "/roblox-callback.html" },
    { "source": "/connect",          "destination": "/api/connect" },
    { "source": "/heartbeat",        "destination": "/api/heartbeat" },
    { "source": "/command_result",   "destination": "/api/command_result" },
    { "source": "/plugin-status",    "destination": "/api/plugin-status" },
    { "source": "/queue-command",    "destination": "/api/queue-command" }
  ]
}
